# Disable source map generation in production builds.
GENERATE_SOURCEMAP=false

# Backend API base URL used by the frontend.
REACT_APP_API_URL=http://localhost:8000

# Application mode flag for local development behavior.
REACT_APP_DEV_MODE=DEVELOP

# Bind the dev server to all network interfaces.
HOST=0.0.0.0

# Prevent CRA from opening the browser automatically.
BROWSER=none

# Enable polling for file changes in Docker/WSL environments.
CHOKIDAR_USEPOLLING="true"
WATCHPACK_POLLING="true"

# WebSocket port used by the webpack dev server.
WDS_SOCKET_PORT="3000"
